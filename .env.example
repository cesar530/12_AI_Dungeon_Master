# AI Dungeon Master - Environment Configuration
# Copiar este archivo a .env y configurar las variables

# OpenAI API Key (opcional - solo si usas el provider 'openai')
OPENAI_API_KEY=tu_api_key_aqui

# Ollama Configuration (opcional - solo si usas Ollama en otra máquina)
OLLAMA_BASE_URL=http://localhost:11434

# Default Model Settings
DEFAULT_PROVIDER=fallback
DEFAULT_MODEL=llama3.2

# Campaign Settings
DEFAULT_CAMPAIGN_PATH=./campaigns
AUTO_SAVE=false
